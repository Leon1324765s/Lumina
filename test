                Create("UICorner", { Parent = Input, CornerRadius = UDim.new(0, 4) })
                Create("UIStroke", { Parent = Input, Color = Library.Theme.Outline, Thickness = 1 })
                Create("UIPadding", { Parent = Input, PaddingLeft = UDim.new(0, 5) })
                
                Input.FocusLost:Connect(function(enter)
                    callback(Input.Text, enter)
                end)
            end

            return Section
        end

        return Tab
    end
    
    return Window
end

return Library
