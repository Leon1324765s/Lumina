-- Utility Functions
local function Tween(instance, info, goals)
    local tween = TweenService:Create(instance, TweenInfo.new(unpack(info)), goals)
    tween:Play()
    return tween
end

local function Create(class, properties)
    local instance = Instance.new(class)
    for k, v in pairs(properties) do
        instance[k] = v
    end
    return instance
end

local function MakeDraggable(topbarobject, object)
    local Dragging = nil
    local DragInput = nil
    local DragStart = nil
    local StartPosition = nil

    local function Update(input)
        local Delta = input.Position - DragStart
        local pos = UDim2.new(StartPosition.X.Scale, StartPosition.X.Offset + Delta.X, StartPosition.Y.Scale, StartPosition.Y.Offset + Delta.Y)
        object.Position = pos
    end

    topbarobject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = input.Position
            StartPosition = object.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                end
            end)
        end
    end)

    topbarobject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            DragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == DragInput and Dragging then
            Update(input)
        end
    end)
end



-- Config System
function Library:SaveConfig(name)
    if not writefile then return end
    local json = HttpService:JSONEncode(Library.Flags)
    writefile(name .. ".json", json)
    Library:Notify("Config Saved: " .. name, 3)
end

function Library:LoadConfig(name)
    if not readfile or not isfile or not isfile(name .. ".json") then return end
    local json = readfile(name .. ".json")
    local data = HttpService:JSONDecode(json)
    
    for flag, value in pairs(data) do
        if Library.Flags[flag] then
            -- This part requires the components to listen to Flag changes or we need a way to set them.
            -- For now, we just load the data. A full implementation would update the UI.
            Library.Flags[flag] = value
        end
    end
    Library:Notify("Config Loaded: " .. name, 3)
end

-- Notification System
function Library:Notify(text, duration)
    local ScreenGui = gethui():FindFirstChild("GeminiUI")
    if not ScreenGui then return end
    
    local NotificationContainer = ScreenGui:FindFirstChild("NotificationContainer")
    if not NotificationContainer then
        NotificationContainer = Create("Frame", {
            Name = "NotificationContainer",
            Parent = ScreenGui,
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -220, 1, -20),
            Size = UDim2.new(0, 200, 1, 0),
            AnchorPoint = Vector2.new(0, 1)
        })
        Create("UIListLayout", {
            Parent = NotificationContainer,
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 5),
            VerticalAlignment = Enum.VerticalAlignment.Bottom
        })
    end

    local NotifyFrame = Create("Frame", {
        Name = "NotifyFrame",
        Parent = NotificationContainer,
        BackgroundColor3 = Library.Theme.Section,
        Size = UDim2.new(1, 0, 0, 0), -- Animated
        ClipsDescendants = true
    })
    Create("UICorner", { Parent = NotifyFrame, CornerRadius = UDim.new(0, 4) })
    Create("UIStroke", { Parent = NotifyFrame, Color = Library.Theme.Outline, Thickness = 1 })
    
    local Label = Create("TextLabel", {
        Parent = NotifyFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -10, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = Library.Theme.Text,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true
    })

    -- Animate In
    Tween(NotifyFrame, {0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {Size = UDim2.new(1, 0, 0, 40)})
    
    task.delay(duration or 3, function()
        -- Animate Out
        Tween(NotifyFrame, {0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In}, {Size = UDim2.new(1, 0, 0, 0)})
        wait(0.3)
        NotifyFrame:Destroy()
    end)
end

