    })
    Create("UICorner", { Parent = Frame, CornerRadius = UDim.new(0, 6) })
    Create("UIStroke", { Parent = Frame, Color = Lumina.Theme.Outline, Thickness = 1 })
    
    local AccentBar = Create("Frame", {
