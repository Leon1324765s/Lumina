                Create("UICorner", { Parent = DropBtn, CornerRadius = UDim.new(0, 6) })
                Create("UIStroke", { Parent = DropBtn, Color = Lumina.Theme.Outline, Thickness = 1 })
                
                local Arrow = Create("ImageLabel", {
                    Parent = DropBtn,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -8, 0.5, 0),
                    Size = UDim2.new(0, 16, 0, 16),
                    BackgroundTransparency = 1,
                    Image = "rbxassetid://6034818372",
                    ImageColor3 = Lumina.Theme.SubText
                })

                local DropList = Create("ScrollingFrame", {
                    Parent = DropBtn,
                    Position = UDim2.new(0, 0, 1, 5),
                    Size = UDim2.new(1, 0, 0, 0),
                    BackgroundColor3 = Lumina.Theme.Section,
                    BorderSizePixel = 0,
                    Visible = false,
                    ZIndex = 10,
                    ScrollBarThickness = 2
                })
                Create("UICorner", { Parent = DropList, CornerRadius = UDim.new(0, 6) })
                Create("UIStroke", { Parent = DropList, Color = Lumina.Theme.Outline, Thickness = 1 })
                local ListLayout = Create("UIListLayout", { Parent = DropList, SortOrder = Enum.SortOrder.LayoutOrder })
                
                local open = false
                DropBtn.MouseButton1Click:Connect(function()
                    open = not open
                    Tween(Arrow, {0.3}, {Rotation = open and 180 or 0})
                    if open then
                        DropList.Visible = true
                        Tween(DropList, {0.4, Enum.EasingStyle.Quart}, {Size = UDim2.new(1, 0, 0, math.min(#list * 30, 150))})
                    else
                        Tween(DropList, {0.4, Enum.EasingStyle.Quart}, {Size = UDim2.new(1, 0, 0, 0)})
                        task.wait(0.4)
                        if not open then DropList.Visible = false end
                    end
                end)

                for _, item in pairs(list) do
                    local ItemBtn = Create("TextButton", {
                        Parent = DropList,
                        Size = UDim2.new(1, 0, 0, 30),
                        BackgroundTransparency = 1,
                        Font = Enum.Font.Gotham,
                        Text = "  " .. tostring(item),
                        TextColor3 = Lumina.Theme.SubText,
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 11
                    })
                    ItemBtn.MouseButton1Click:Connect(function()
                        DropBtn.Text = "  " .. tostring(item)
                        Lumina.Flags[flag] = item
                        callback(item)
                        open = false
                        Tween(Arrow, {0.3}, {Rotation = 0})
                        Tween(DropList, {0.4, Enum.EasingStyle.Quart}, {Size = UDim2.new(1, 0, 0, 0)})
                        task.wait(0.4)
                        DropList.Visible = false
                    end)
                end
            end

            -- Label
            function Section:Label(text, color)
                local Label = Create("TextLabel", {
                    Parent = ItemContainer,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 20),
                    Font = Enum.Font.Gotham,
                    Text = text,
                    TextColor3 = color or Lumina.Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                return {
                    Set = function(val) Label.Text = val end,
                    SetColor = function(val) Label.TextColor3 = val end
                }
            end

            -- Paragraph
            function Section:Paragraph(title, content)
                local Frame = Create("Frame", {
                    Parent = ItemContainer,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y
                })
                local TLabel = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 20),
                    Font = Enum.Font.GothamBold,
                    Text = title,
                    TextColor3 = Lumina.Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                local CLabel = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 20),
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Font = Enum.Font.Gotham,
                    Text = content,
                    TextColor3 = Lumina.Theme.SubText,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true
                })
            end

            -- Textbox
            function Section:Textbox(text, placeholder, flag, callback)
                flag = flag or text
                callback = callback or function() end
                
                local Frame = Create("Frame", {
                    Parent = ItemContainer,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 55)
                })
                local Label = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 20),
                    Font = Enum.Font.Gotham,
                    Text = text,
                    TextColor3 = Lumina.Theme.SubText,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                local Input = Create("TextBox", {
                    Parent = Frame,
                    Position = UDim2.new(0, 0, 0, 22),
                    Size = UDim2.new(1, 0, 0, 30),
                    BackgroundColor3 = Lumina.Theme.Highlight,
                    Font = Enum.Font.Gotham,
                    Text = "",
                    PlaceholderText = placeholder or "Type here...",
                    PlaceholderColor3 = Lumina.Theme.SubText,
                    TextColor3 = Lumina.Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ClearTextOnFocus = false
                })
                Create("UICorner", { Parent = Input, CornerRadius = UDim.new(0, 6) })
                Create("UIStroke", { Parent = Input, Color = Lumina.Theme.Outline, Thickness = 1 })
                Create("UIPadding", { Parent = Input, PaddingLeft = UDim.new(0, 10) })

                Input.FocusLost:Connect(function(enter)
                    Lumina.Flags[flag] = Input.Text
                    callback(Input.Text, enter)
                end)
            end

            -- Keybind
            function Section:Keybind(text, default, flag, callback)
                default = default or Enum.KeyCode.F
                flag = flag or text
                callback = callback or function() end
                
                local binding = false
                Lumina.Flags[flag] = default

                local Frame = Create("Frame", {
                    Parent = ItemContainer,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 30)
                })
                local Label = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -100, 1, 0),
                    Font = Enum.Font.Gotham,
                    Text = text,
                    TextColor3 = Lumina.Theme.SubText,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local BindBtn = Create("TextButton", {
                    Parent = Frame,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.new(0, 80, 0, 22),
                    BackgroundColor3 = Lumina.Theme.Highlight,
                    Font = Enum.Font.GothamMedium,
                    Text = default.Name,
                    TextColor3 = Lumina.Theme.Text,
                    TextSize = 12,
                    AutoButtonColor = false
                })
                Create("UICorner", { Parent = BindBtn, CornerRadius = UDim.new(0, 4) })
                Create("UIStroke", { Parent = BindBtn, Color = Lumina.Theme.Outline, Thickness = 1 })

                BindBtn.MouseButton1Click:Connect(function()
                    binding = true
                    BindBtn.Text = "..."
                    local input = UserInputService.InputBegan:Wait()
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        Lumina.Flags[flag] = input.KeyCode
                        BindBtn.Text = input.KeyCode.Name
                        binding = false
                        callback(input.KeyCode)
                    end
                end)
            end

            -- ColorPicker (Advanced)
            function Section:ColorPicker(text, default, flag, callback)
                default = default or Color3.fromRGB(255, 255, 255)
                flag = flag or text
                callback = callback or function() end
                
                Lumina.Flags[flag] = default
                
                local h, s, v = default:ToHSV()

                local Frame = Create("Frame", {
                    Parent = ItemContainer,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 30)
                })
                local Label = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -50, 1, 0),
                    Font = Enum.Font.Gotham,
                    Text = text,
                    TextColor3 = Lumina.Theme.SubText,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local ColorBtn = Create("TextButton", {
                    Parent = Frame,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.new(0, 40, 0, 20),
                    BackgroundColor3 = default,
                    Text = ""
                })
                Create("UICorner", { Parent = ColorBtn, CornerRadius = UDim.new(0, 4) })
                Create("UIStroke", { Parent = ColorBtn, Color = Lumina.Theme.Outline, Thickness = 1 })

                local PickerFrame = Create("Frame", {
                    Parent = ItemContainer,
                    BackgroundColor3 = Lumina.Theme.Highlight,
                    Size = UDim2.new(1, 0, 0, 150),
                    Visible = false
                })
                Create("UICorner", { Parent = PickerFrame, CornerRadius = UDim.new(0, 6) })
                
                -- Simplified HSV logic
                local SatMap = Create("ImageLabel", {
                    Parent = PickerFrame,
                    Position = UDim2.new(0, 10, 0, 10),
                    Size = UDim2.new(1, -60, 1, -20),
                    Image = "rbxassetid://4155801252"
                })
                
                ColorBtn.MouseButton1Click:Connect(function()
                    PickerFrame.Visible = not PickerFrame.Visible
                end)
            end

            return Section
        end

        return Tab
    end
    
    return Window
end

